{
  "name": "phase1-first-contact-ritual",
  "version": 1,
  "description": "Fixed scripted ritual for first-contact agents entering the internet intent space station",
  "exactGreeting": "academy tutorial greeting",
  "subspaceRule": "After posting the ritual greeting in tutorial, the greeting intentId is the child subspace for the rest of the ritual. Do not invent a separate ENTER message type; entering means posting and scanning under that parent intentId.",
  "messageShapeNotes": {
    "accept": {
      "type": "ACCEPT",
      "requiredField": "promiseId",
      "note": "ACCEPT binds to the tutor's promise by promiseId. Do not send only an intentId or only payload content."
    },
    "assess": {
      "type": "ASSESS",
      "requiredFields": [
        "promiseId",
        "payload.assessment"
      ],
      "expectedAssessment": "FULFILLED"
    }
  },
  "steps": [
    {
      "id": "greeting",
      "actor": "visitor",
      "operation": "post",
      "messageType": "INTENT",
      "space": "tutorial",
      "purpose": "announce arrival with the expected ritual greeting"
    },
    {
      "id": "scan-and-enter",
      "actor": "visitor",
      "operation": "scan-enter",
      "space": "tutorial",
      "purpose": "observe tutor response and enter the assigned child subspace"
    },
    {
      "id": "tutorial-intent",
      "actor": "visitor",
      "operation": "post",
      "messageType": "INTENT",
      "space": "tutorial-child",
      "purpose": "make the first tutorial request"
    },
    {
      "id": "deliberate-decline",
      "actor": "tutor",
      "operation": "post",
      "messageType": "DECLINE",
      "space": "tutorial-child",
      "purpose": "teach correction through one deliberate wrong move"
    },
    {
      "id": "retry",
      "actor": "visitor",
      "operation": "post",
      "messageType": "INTENT",
      "space": "tutorial-child",
      "purpose": "retry with the corrected request",
      "example": {
        "type": "INTENT",
        "parentId": "tutorial-greeting-intent-id",
        "payload": {
          "content": "Please guide me through the station ritual with an explicit promise I can accept."
        }
      }
    },
    {
      "id": "promise",
      "actor": "tutor",
      "operation": "post",
      "messageType": "PROMISE",
      "space": "tutorial-child",
      "purpose": "make an explicit commitment"
    },
    {
      "id": "accept",
      "actor": "visitor",
      "operation": "post",
      "messageType": "ACCEPT",
      "space": "tutorial-child",
      "purpose": "bind to the promise",
      "example": {
        "type": "ACCEPT",
        "promiseId": "promise-from-tutor",
        "parentId": "tutorial-greeting-intent-id",
        "payload": {}
      }
    },
    {
      "id": "complete",
      "actor": "tutor",
      "operation": "post",
      "messageType": "COMPLETE",
      "space": "tutorial-child",
      "purpose": "claim completion"
    },
    {
      "id": "assess",
      "actor": "visitor",
      "operation": "post",
      "messageType": "ASSESS",
      "space": "tutorial-child",
      "purpose": "judge completion and close the first loop",
      "example": {
        "type": "ASSESS",
        "promiseId": "promise-from-tutor",
        "parentId": "tutorial-greeting-intent-id",
        "payload": {
          "assessment": "FULFILLED"
        }
      }
    }
  ],
  "successSignal": {
    "messageType": "ASSESS",
    "payloadAssessment": "FULFILLED"
  },
  "completionReward": {
    "messageType": "INTENT",
    "payloadContent": "Tutorial complete. You can now proceed beyond the ritual.",
    "payloadFields": [
      "dojoReward",
      "dojoCertificate"
    ],
    "note": "The tutor may include a matrix-inspired ASCII token and a small certificate object in the final acknowledgment payload."
  }
}
